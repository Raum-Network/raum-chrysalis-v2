{
  "name": "chrysalis-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Chrysalis V2 integrating Circle Gateway, CCTP, BridgeKit, paymasters, nanopayments, EURC, and cross-chain protocol adapters.",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm --filter @arc-os/api dev",
    "dev:web": "pnpm --filter @arc-os/web dev",
    "dev:agent": "pnpm --filter @arc-os/agent-worker dev",
    "test:contracts": "cd contracts && forge test -vvv",
    "deploy:arc": "cd contracts && forge script script/DeployArc.s.sol:DeployArc --rpc-url $ARC_RPC_URL --broadcast",
    "deploy:base": "cd contracts && DESTINATION_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e forge script script/DeployDestination.s.sol:DeployDestination --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast",
    "deploy:ethereum": "cd contracts && DESTINATION_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238 forge script script/DeployDestination.s.sol:DeployDestination --rpc-url $ETHEREUM_SEPOLIA_RPC_URL --broadcast",
    "register:adapters": "tsx scripts/register-adapters.ts",
    "build:solana": "cd programs/solana && anchor build",
    "build:stellar": "cd programs/stellar && cargo build --target wasm32-unknown-unknown --release",
    "deploy:solana-adapters": "bash scripts/deploy-solana-adapters.sh",
    "deploy:stellar-adapters": "bash scripts/deploy-stellar-adapters.sh"
  },
  "devDependencies": {
    "@scure/bip32": "^2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^15.1.0",
    "@types/node": "^20.14.12",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.1.3",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.9.0",
  "pnpm": {
    "overrides": {
      "rpc-websockets@9.3.9>uuid": "11.1.0"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
